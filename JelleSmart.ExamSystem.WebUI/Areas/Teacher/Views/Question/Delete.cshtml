@model JelleSmart.ExamSystem.Core.Entities.Question

@{
    ViewData["Title"] = "Soru Sil";
}

<h2>Soru Sil</h2>

<div class="alert alert-danger">
    <p>Bu soruyu silmek istediğinizden emin misiniz?</p>
</div>

<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title">Soru</h5>
        <p>@Model.Text</p>

        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <div class="mt-2">
                <img src="~/@Model.ImageUrl" alt="Soru görseli" style="max-width: 300px;" class="img-thumbnail" />
            </div>
        }
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h6>Şıklar</h6>
        <ul class="list-group">
            @foreach (var choice in Model.Choices)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span>@choice.Label) @choice.Text</span>
                    @if (choice.IsCorrect)
                    {
                        <span class="badge bg-success">Doğru</span>
                    }
                </li>
            }
        </ul>
    </div>
</div>

<form method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Sil</button>
    <a asp-action="Index" class="btn btn-secondary">İptal</a>
</form>

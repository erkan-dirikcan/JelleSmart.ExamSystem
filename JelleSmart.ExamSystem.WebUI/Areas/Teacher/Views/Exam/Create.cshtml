@model JelleSmart.ExamSystem.WebUI.Models.CreateExamViewModel

@{
    ViewData["Title"] = "Yeni Sınav";
}

<h2>Yeni Sınav Oluştur</h2>

<form method="post" id="examForm">
    <div class="row">
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title">Sınav Bilgileri</h5>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Sınav Adı</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Açıklama</label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Duration" class="form-label">Süre (Dakika)</label>
                            <input asp-for="Duration" class="form-control" type="number" min="1" max="180" />
                            <span asp-validation-for="Duration" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="QuestionCount" class="form-label">Soru Sayısı</label>
                            <input asp-for="QuestionCount" class="form-control" type="number" min="1" max="100" id="questionCount" />
                            <span asp-validation-for="QuestionCount" class="text-danger"></span>
                            <small class="text-muted">Mevcut soru sayısı: <span id="availableCount">-</span></small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="TotalPoints" class="form-label">Toplam Puan</label>
                        <input asp-for="TotalPoints" class="form-control" type="number" min="1" max="1000" step="0.5" />
                        <span asp-validation-for="TotalPoints" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartDate" class="form-label">Başlangıç Tarihi</label>
                            <input asp-for="StartDate" class="form-control" type="datetime-local" />
                            <span asp-validation-for="StartDate" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="EndDate" class="form-label">Bitiş Tarihi</label>
                            <input asp-for="EndDate" class="form-control" type="datetime-local" />
                            <span asp-validation-for="EndDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="SubjectId" class="form-label">Ders</label>
                            <select asp-for="SubjectId" class="form-select" id="subjectSelect">
                                <option value="">Seçiniz...</option>
                                @foreach (var subject in ViewBag.Subjects)
                                {
                                    <option value="@subject.Id">@subject.Name</option>
                                }
                            </select>
                            <span asp-validation-for="SubjectId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="GradeId" class="form-label">Sınıf</label>
                            <select asp-for="GradeId" class="form-select">
                                <option value="">Seçiniz...</option>
                                @foreach (var grade in ViewBag.Grades)
                                {
                                    <option value="@grade.Id">@grade.Name</option>
                                }
                            </select>
                            <span asp-validation-for="GradeId" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Kazanım Seçimi (Opsiyonel)</h5>
                    <p class="text-muted">Sadece seçilen kazanımlardan soru seçilecektir. Boş bırakılırsa dersteki tüm sorular arasından seçim yapılır.</p>

                    <div id="topicsContainer" class="border rounded p-3" style="max-height: 300px; overflow-y: auto;">
                        <p class="text-muted">Önce ders seçiniz.</p>
                    </div>

                    <input type="hidden" asp-for="TopicIds" id="topicIdsInput" />
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Oluştur</button>
        <a asp-action="Index" class="btn btn-secondary">İptal</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        let selectedTopics = [];

        document.getElementById('subjectSelect').addEventListener('change', function() {
            const subjectId = this.value;
            const container = document.getElementById('topicsContainer');

            if (subjectId) {
                fetch('/Teacher/Exam/GetTopicsBySubject', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(subjectId)
                })
                .then(res => res.json())
                .then(data => {
                    container.innerHTML = '';
                    if (data.length === 0) {
                        container.innerHTML = '<p class="text-muted">Bu derste kazanım bulunmamaktadır.</p>';
                    } else {
                        data.forEach(topic => {
                            container.innerHTML += `
                                <div class="form-check">
                                    <input class="form-check-input topic-checkbox" type="checkbox"
                                           value="${topic.id}" id="topic_${topic.id}">
                                    <label class="form-check-label" for="topic_${topic.id}">
                                        ${topic.code || ''} ${topic.name}
                                    </label>
                                </div>
                            `;
                        });

                        // Checkbox event listeners
                        container.querySelectorAll('.topic-checkbox').forEach(cb => {
                            cb.addEventListener('change', updateTopicIds);
                        });
                    }
                    updateQuestionCount();
                });
            } else {
                container.innerHTML = '<p class="text-muted">Önce ders seçiniz.</p>';
                selectedTopics = [];
                updateTopicIds();
            }
        });

        function updateTopicIds() {
            const checkboxes = document.querySelectorAll('.topic-checkbox:checked');
            selectedTopics = Array.from(checkboxes).map(cb => parseInt(cb.value));
            document.getElementById('topicIdsInput').value = JSON.stringify(selectedTopics);
            updateQuestionCount();
        }

        function updateQuestionCount() {
            const subjectId = document.getElementById('subjectSelect').value;
            const countSpan = document.getElementById('availableCount');

            if (!subjectId) {
                countSpan.textContent = '-';
                return;
            }

            fetch('/Teacher/Exam/GetQuestionCount', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    subjectId: parseInt(subjectId),
                    unitId: null,
                    topicIds: selectedTopics.length > 0 ? selectedTopics : null
                })
            })
            .then(res => res.json())
            .then(data => {
                countSpan.textContent = data.count;
            });
        }
    </script>
}

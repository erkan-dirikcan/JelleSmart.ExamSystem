@model IEnumerable<JelleSmart.ExamSystem.Core.Entities.Exam>

@{
    ViewData["Title"] = "Sınavlarım";
}

<h2>Sınavlarım</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Yeni Sınav Oluştur</a>
</p>

<div class="table-responsive">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Sınav Adı</th>
                <th>Ders</th>
                <th>Sınıf</th>
                <th>Süre</th>
                <th>Soru Sayısı</th>
                <th>Durum</th>
                <th>Başlangıç</th>
                <th>Bitiş</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Subject?.Name</td>
                    <td>@item.Grade?.Name</td>
                    <td>@item.Duration dk</td>
                    <td>@item.QuestionCount</td>
                    <td>
                        @if (item.IsActive)
                        {
                            <span class="badge bg-success">Aktif</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Pasif</span>
                        }
                    </td>
                    <td>@item.StartTime.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@item.EndTime.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Detay</a>
                        <a asp-action="Results" asp-route-id="@item.Id" class="btn btn-sm btn-success">Sonuçlar</a>
                        @if (item.IsActive)
                        {
                            <a asp-action="Deactivate" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Pasife Al</a>
                        }
                        else
                        {
                            <a asp-action="Activate" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Aktifleştir</a>
                        }
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger"
                           onclick="return confirm('Silmek istediğinizden emin misiniz?')">Sil</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

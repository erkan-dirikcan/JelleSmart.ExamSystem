@model JelleSmart.ExamSystem.WebUI.Models.TakeExamViewModel

@{
    ViewData["Title"] = "Sınav";
    var currentQuestionIndex = 0;
}

<div class="sticky-top bg-white pt-2 pb-2 border-bottom" style="top: 56px; z-index: 1000;">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col">
                <h5 class="mb-0">@Model.ExamName</h5>
            </div>
            <div class="col-auto">
                <div class="d-flex align-items-center gap-3">
                    <div>
                        <strong>Kalan Süre:</strong>
                        <span id="timer" class="badge @(Model.RemainingTime < 300 ? "bg-danger" : "bg-primary")">
                            @TimeSpan.FromSeconds(Model.RemainingTime).ToString(@"hh\:mm\:ss")
                        </span>
                    </div>
                    <button id="completeExamBtn" class="btn btn-success">Sınavı Bitir</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h6 class="card-title">Sorular</h6>
                    <div class="d-flex flex-wrap gap-1" id="questionNav">
                        @for (int i = 0; i < Model.Questions.Count; i++)
                        {
                            var q = Model.Questions[i];
                            var answered = q.SelectedChoiceId.HasValue;
                            <button class="btn @(answered ? "btn-success" : "btn-outline-secondary") question-nav-btn"
                                    data-index="@i"
                                    style="width: 40px; height: 40px;">
                                @(i + 1)
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <div id="questionsContainer">
                @foreach (var question in Model.Questions.Select((q, i) => new { Question = q, Index = i }))
                {
                    <div class="question-card" data-index="@question.Index" style="display: @(question.Index == 0 ? "block" : "none");">
                        <div class="card">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <h5>Soru @(question.Index + 1)</h5>
                                    <span class="badge bg-secondary">@(Model.Questions.Sum(q => q.Choices.Count > 0 ? (double)Model.Questions.Sum(eq => 1) / Model.Questions.Count : 0) * Model.Questions.Count) puan</span>
                                </div>

                                <p class="lead">@question.Question.Text</p>

                                @if (!string.IsNullOrEmpty(question.Question.ImageUrl))
                                {
                                    <div class="mb-3">
                                        <img src="~/@question.Question.ImageUrl" alt="Soru görseli" class="img-fluid img-thumbnail" />
                                    </div>
                                }

                                <div class="list-group">
                                    @foreach (var choice in question.Question.Choices)
                                    {
                                        <label class="list-group-item list-group-item-action choice-label"
                                               data-choice-id="@choice.Id">
                                            <input class="form-check-input me-2" type="radio"
                                                   name="question_@question.Question.QuestionId"
                                                   value="@choice.Id"
                                                   @(question.Question.SelectedChoiceId == choice.Id ? "checked" : "")
                                                   onchange="saveAnswer(@question.Question.QuestionId, @choice.Id)" />
                                            <span class="choice-label-text">@choice.Label) @choice.Text</span>
                                            @if (!string.IsNullOrEmpty(choice.ImageUrl))
                                            {
                                                <br />
                                                <img src="~/@choice.ImageUrl" alt="Şık görseli" class="img-fluid img-thumbnail ms-4 mt-2" style="max-width: 200px;" />
                                            }
                                        </label>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="d-flex justify-content-between mt-3">
                <button id="prevBtn" class="btn btn-primary" disabled>Önceki</button>
                <button id="nextBtn" class="btn btn-primary">Sonraki</button>
            </div>
        </div>
    </div>
</div>

<form id="completeForm" asp-action="Complete" method="post">
    <input type="hidden" name="id" value="@Model.StudentExamId" />
</form>

@section Scripts {
    <script>
        let currentQuestion = 0;
        const totalQuestions = @Model.Questions.Count;
        let remainingSeconds = @Model.RemainingTime;
        let timerInterval;

        // Timer
        function startTimer() {
            timerInterval = setInterval(function() {
                remainingSeconds--;
                const hours = Math.floor(remainingSeconds / 3600);
                const minutes = Math.floor((remainingSeconds % 3600) / 60);
                const seconds = remainingSeconds % 60;

                const timerEl = document.getElementById('timer');
                timerEl.textContent = `${String(hours).padStart(2, '0')}:${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;

                if (remainingSeconds < 300) {
                    timerEl.classList.remove('bg-primary');
                    timerEl.classList.add('bg-danger');
                }

                if (remainingSeconds <= 0) {
                    clearInterval(timerInterval);
                    document.getElementById('completeForm').submit();
                }
            }, 1000);
        }

        // Question navigation
        function showQuestion(index) {
            document.querySelectorAll('.question-card').forEach(el => el.style.display = 'none');
            document.querySelector(`.question-card[data-index="${index}"]`).style.display = 'block';

            document.getElementById('prevBtn').disabled = (index === 0);
            document.getElementById('nextBtn').disabled = (index === totalQuestions - 1);

            currentQuestion = index;
        }

        document.getElementById('prevBtn').addEventListener('click', () => {
            if (currentQuestion > 0) showQuestion(currentQuestion - 1);
        });

        document.getElementById('nextBtn').addEventListener('click', () => {
            if (currentQuestion < totalQuestions - 1) showQuestion(currentQuestion + 1);
        });

        document.querySelectorAll('.question-nav-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                showQuestion(parseInt(this.dataset.index));
            });
        });

        // Save answer
        async function saveAnswer(questionId, choiceId) {
            const questionIndex = parseInt(document.querySelector(`input[name="question_${questionId}"]`).closest('.question-card').dataset.index);

            await fetch('/Student/Exam/SubmitAnswer', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify({
                    studentExamId: @Model.StudentExamId,
                    questionId: questionId,
                    choiceId: choiceId
                })
            });

            // Update navigation button
            const navBtn = document.querySelector(`.question-nav-btn[data-index="${questionIndex}"]`);
            navBtn.classList.remove('btn-outline-secondary');
            navBtn.classList.add('btn-success');
        }

        // Complete exam
        document.getElementById('completeExamBtn').addEventListener('click', () => {
            if (confirm('Sınavı bitirmek istediğinizden emin misiniz?')) {
                clearInterval(timerInterval);
                document.getElementById('completeForm').submit();
            }
        });

        // Start
        startTimer();
    </script>
}

@model JelleSmart.ExamSystem.Core.DTOs.StudentReportDto

@{
    ViewData["Title"] = "Raporlarım";
}

<h2>Performans Raporum</h2>

<div class="row">
    <div class="col-md-3">
        <div class="card text-center mb-3">
            <div class="card-body">
                <h5 class="card-title">Toplam Sınav</h5>
                <h2 class="text-primary">@Model.TotalExams</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-center mb-3">
            <div class="card-body">
                <h5 class="card-title">Tamamlanan</h5>
                <h2 class="text-success">@Model.CompletedExams</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-center mb-3">
            <div class="card-body">
                <h5 class="card-title">Ortalama Puan</h5>
                <h2 class="text-info">@Model.AverageScore.ToString("F1")</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-center mb-3">
            <div class="card-body">
                <h5 class="card-title">Başarı Oranı</h5>
                <h2 class="@(Model.AveragePercentage >= 70 ? "text-success" : Model.AveragePercentage >= 50 ? "text-warning" : "text-danger")">
                    @Model.AveragePercentage.ToString("F1")%
                </h2>
            </div>
        </div>
    </div>
</div>

@if (Model.SubjectPerformances.Any())
{
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Ders Bazlı Performans</h5>
                    <canvas id="subjectChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Ders Bazlı Sınav Sayısı</h5>
                    <canvas id="subjectCountChart"></canvas>
                </div>
            </div>
        </div>
    </div>
}

<div class="card">
    <div class="card-body">
        <h5 class="card-title">Ders Bazlı Detaylar</h5>

        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Ders</th>
                        <th>Sınav Sayısı</th>
                        <th>Ortalama Puan</th>
                        <th>Başarı Oranı</th>
                        <th>İlerleme</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var subject in Model.SubjectPerformances)
                    {
                        <tr>
                            <td>@subject.SubjectName</td>
                            <td>@subject.ExamCount</td>
                            <td>@subject.AverageScore.ToString("F1")</td>
                            <td>
                                <span class="badge @(subject.AveragePercentage >= 70 ? "bg-success" : subject.AveragePercentage >= 50 ? "bg-warning" : "bg-danger")">
                                    @subject.AveragePercentage.ToString("F1")%
                                </span>
                            </td>
                            <td>
                                <div class="progress" style="height: 20px;">
                                    <div class="progress-bar @(subject.AveragePercentage >= 70 ? "bg-success" : subject.AveragePercentage >= 50 ? "bg-warning" : "bg-danger")"
                                         role="progressbar" style="width: @subject.AveragePercentage%">
                                        @subject.AveragePercentage.ToString("F1")%
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="mt-3">
    <h5>Sınav Sonuçları</h5>
    <a asp-action="ExamResults" class="btn btn-info">Tüm Sonuçları Gör</a>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const subjects = @Json.Serialize(Model.SubjectPerformances.Select(s => s.SubjectName));
        const scores = @Json.Serialize(Model.SubjectPerformances.Select(s => s.AverageScore));
        const percentages = @Json.Serialize(Model.SubjectPerformances.Select(s => s.AveragePercentage));
        const counts = @Json.Serialize(Model.SubjectPerformances.Select(s => s.ExamCount));

        // Subject Performance Chart
        new Chart(document.getElementById('subjectChart'), {
            type: 'bar',
            data: {
                labels: subjects,
                datasets: [{
                    label: 'Başarı Oranı (%)',
                    data: percentages,
                    backgroundColor: percentages.map(p => p >= 70 ? 'rgba(25, 135, 84, 0.7)' : p >= 50 ? 'rgba(255, 193, 7, 0.7)' : 'rgba(220, 53, 69, 0.7)'),
                    borderColor: percentages.map(p => p >= 70 ? 'rgb(25, 135, 84)' : p >= 50 ? 'rgb(255, 193, 7)' : 'rgb(220, 53, 69)'),
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        max: 100
                    }
                },
                plugins: {
                    legend: {
                        display: false
                    }
                }
            }
        });

        // Subject Count Chart
        new Chart(document.getElementById('subjectCountChart'), {
            type: 'doughnut',
            data: {
                labels: subjects,
                datasets: [{
                    data: counts,
                    backgroundColor: [
                        'rgba(13, 110, 253, 0.7)',
                        'rgba(25, 135, 84, 0.7)',
                        'rgba(255, 193, 7, 0.7)',
                        'rgba(220, 53, 69, 0.7)',
                        'rgba(13, 202, 240, 0.7)',
                        'rgba(102, 16, 242, 0.7)'
                    ]
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });
    </script>
}

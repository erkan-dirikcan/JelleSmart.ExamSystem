@model JelleSmart.ExamSystem.WebUI.Models.UserViewModel

@{
    ViewData["Title"] = "Kullanıcı Detay";
}

<h2>Kullanıcı Detay</h2>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Ad Soyad</dt>
            <dd class="col-sm-9">@Model.FullName</dd>

            <dt class="col-sm-3">E-posta</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Rol</dt>
            <dd class="col-sm-9">
                @switch (Model.Role)
                {
                    case "Admin": <span class="badge bg-danger">Admin</span> break;
                    case "Teacher": <span class="badge bg-primary">Öğretmen</span> break;
                    case "Student": <span class="badge bg-success">Öğrenci</span> break;
                    default: <span class="badge bg-secondary">@Model.Role</span> break;
                }
            </dd>

            <dt class="col-sm-3">Durum</dt>
            <dd class="col-sm-9">
                @if (Model.IsActive)
                {
                    <span class="badge bg-success">Aktif</span>
                }
                else
                {
                    <span class="badge bg-danger">Pasif</span>
                }
            </dd>

            @if (Model.GradeId.HasValue)
            {
                <dt class="col-sm-3">Sınıf</dt>
                <dd class="col-sm-9">@Model.GradeName</dd>
            }

            @if (Model.SubjectId.HasValue)
            {
                <dt class="col-sm-3">Branş Dersi</dt>
                <dd class="col-sm-9">@Model.SubjectName</dd>
            }
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Listeye Dön</a>
    <a asp-action="ToggleActive" asp-route-id="@Model.Id" class="btn btn-warning">
        @(Model.IsActive ? "Pasife Al" : "Aktife Al")
    </a>
</div>

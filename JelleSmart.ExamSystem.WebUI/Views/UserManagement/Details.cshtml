@model JelleSmart.ExamSystem.Core.ViewModels.UserViewModel

@{
    ViewData["Title"] = "Kullanıcı Detay";
}

<div class="d-flex flex-column-fluid">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12">
                <div class="card card-custom">
                    <div class="card-header flex-wrap border-0 pt-6 pb-0">
                        <div class="card-title">
                            <h3 class="card-label">
                                Kullanıcılar
                                <span class="d-block text-muted pt-2 font-size-sm">Kullanıcı Detay</span>
                            </h3>
                        </div>


                        <div class="card-body">
                            <dl class="row">
                                <dt class="col-sm-3">Ad Soyad</dt>
                                <dd class="col-sm-9">@Model.FullName</dd>

                                <dt class="col-sm-3">E-posta</dt>
                                <dd class="col-sm-9">@Model.Email</dd>

                                <dt class="col-sm-3">Rol</dt>
                                <dd class="col-sm-9">
                                    @switch (Model.Role)
                                    {
                                        case "Admin":
                                            <span class="badge bg-danger">Admin</span>
                                            break;
                                        case "Teacher":

                                            <span class="badge bg-primary">Öğretmen</span>
                                            break;
                                        case "Student":

                                            <span class="badge bg-success">Öğrenci</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary">@Model.Role</span>
                                            break;
                                    }
                                </dd>

                                <dt class="col-sm-3">Durum</dt>
                                <dd class="col-sm-9">
                                    @if (Model.IsActive)
                                    {
                                        <span class="badge bg-success">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Pasif</span>
                                    }
                                </dd>

                                @if (!string.IsNullOrEmpty(Model.GradeId))
                                {
                                    <dt class="col-sm-3">Sınıf</dt>
                                    <dd class="col-sm-9">@Model.GradeName</dd>
                                }

                                @if (!string.IsNullOrEmpty(Model.SubjectId))
                                {
                                    <dt class="col-sm-3">Branş Dersi</dt>
                                    <dd class="col-sm-9">@Model.SubjectName</dd>
                                }
                            </dl>
        
        
                            <div class="mt-3">
                                <a asp-action="Index" asp-controller="UserManagement" class="btn btn-secondary">Listeye Dön</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

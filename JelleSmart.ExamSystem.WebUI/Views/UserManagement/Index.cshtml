@model List<JelleSmart.ExamSystem.WebUI.Models.UserViewModel>

@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
}

<h2>Kullanıcı Yönetimi</h2>

<div class="table-responsive">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Ad Soyad</th>
                <th>E-posta</th>
                <th>Rol</th>
                <th>Durum</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.FullName</td>
                    <td>@user.Email</td>
                    <td>
                        @switch (user.Role)
                        {
                            case "Admin": <span class="badge bg-danger">Admin</span> break;
                            case "Teacher": <span class="badge bg-primary">Öğretmen</span> break;
                            case "Student": <span class="badge bg-success">Öğrenci</span> break;
                            default: <span class="badge bg-secondary">@user.Role</span> break;
                        }
                    </td>
                    <td>
                        @if (user.IsActive)
                        {
                            <span class="badge bg-success">Aktif</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Pasif</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-info">Detay</a>
                        <a asp-action="ToggleActive" asp-route-id="@user.Id" class="btn btn-sm btn-warning">
                            @(user.IsActive ? "Pasife Al" : "Aktife Al")
                        </a>
                        <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-danger"
                           onclick="return confirm('Bu kullanıcıyı silmek istediğinizden emin misiniz?')">Sil</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="mt-3">
    <a asp-action="Register" asp-controller="Account" class="btn btn-primary">Yeni Kullanıcı Ekle</a>
</div>

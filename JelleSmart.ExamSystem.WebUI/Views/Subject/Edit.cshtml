@model JelleSmart.ExamSystem.Core.ViewModels.SubjectViewModel

@{
    ViewData["Title"] = "Ders Düzenle";
}

<div class="card card-xl-stretch mb-5 mb-xl-8">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold fs-3 mb-1">Ders Düzenle</span>
            <span class="text-muted fw-semibold fs-7">Ders bilgilerini güncelleyin</span>
        </h3>
    </div>
    <div class="card-body py-3">
        <form asp-action="Edit" method="post" id="subjectForm">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" role="alert"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-5">
                <label asp-for="Name" class="form-label">Ders Adı</label>
                <input asp-for="Name" class="form-control form-control-solid" placeholder="Ders adını girin" />
                <span asp-validation-for="Name" class="text-danger fs-7"></span>
            </div>

            <div class="mb-5">
                <label asp-for="Description" class="form-label">Açıklama</label>
                <textarea asp-for="Description" class="form-control form-control-solid" rows="3" placeholder="Ders açıklamasını girin"></textarea>
                <span asp-validation-for="Description" class="text-danger fs-7"></span>
            </div>

            <div class="mb-5">
                <label asp-for="IconClass" class="form-label">İkon Sınıfı (Opsiyonel)</label>
                <input asp-for="IconClass" class="form-control form-control-solid" placeholder="bi bi-book" />
                <span asp-validation-for="IconClass" class="text-danger fs-7"></span>
            </div>

            <div class="d-flex justify-content-end">
                <a asp-action="Index" class="btn btn-light me-3">İptal</a>
                <button type="submit" class="btn btn-primary">
                    <span class="indicator-label">Güncelle</span>
                    <span class="indicator-progress">
                        Lütfen bekleyin...
                        <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                    </span>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/assets/js/custom/subjects-form.js"></script>
}
